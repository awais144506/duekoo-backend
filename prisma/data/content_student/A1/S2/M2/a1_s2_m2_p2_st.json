  "title": "The Accusative Case",
  "deTitle": "Der Akkusativ",
  "sections": [
    {
      "type": "EXPLAINER",
      "title": "The Direct Object",
      "blocks": [
        {
          "heading": "What is the Accusative?",
          "text": "In English, we say 'I eat the apple.' The apple is the direct object. In German, when a **Masculine (Der)** noun is the direct object, its article changes. Feminine, Neuter, and Plural remain exactly the same.",
          "examples": [
            { "exp1": "Subject (Nominative): The coffee is hot." },
            { "exp2": "Object (Accusative): I drink the coffee." }
          ]
        }
      ]
    },
    {
      "type": "TABLE",
      "title": "Article Changes",
      "config": {
        "speechSequence": ["c2", "c3"]
      },
      "headers": ["Gender", "Nominative", "Accusative", "Rule"],
      "rows": [
        { "c1": "Masculine", "c2": "Der / Ein", "c3": "Den / Einen", "c4": "Changes to -en" },
        { "c1": "Feminine", "c2": "Die / Eine", "c3": "Die / Eine", "c4": "Stays the same" },
        { "c1": "Neuter", "c2": "Das / Ein", "c3": "Das / Ein", "c4": "Stays the same" },
        { "c1": "Plural", "c2": "Die", "c3": "Die", "c4": "Stays the same" }
      ]
    },
