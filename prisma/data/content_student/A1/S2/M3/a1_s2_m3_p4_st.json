        { "c1": "Look / Appear", "c2": "Aussehen", "c3": "Owss-zay-en", "c4": "Sie sehen krank aus.", "c5": "Zee zay-en krank owss", "c6": "You look sick." },
        { "c1": "Fill out", "c2": "Ausfüllen", "c3": "Owss-fuel-len", "c4": "Füllen Sie das Formular aus.", "c5": "Fuel-len zee dass For-moo-lar owss", "c6": "Fill out the form." },
        { "c1": "Call", "c2": "Anrufen", "c3": "An-roo-fen", "c4": "Ich rufe den Arzt an.", "c5": "Ish roo-feh dain Artst an", "c6": "I call the doctor." },
        { "c1": "Take (Medicine)", "c2": "Einnehmen", "c3": "Ine-nay-men", "c4": "Nehmen Sie die Medizin ein.", "c5": "Nay-men zee dee Me-dee-tseen ine", "c6": "Take the medicine." },
        { "c1": "Bring along", "c2": "Mitbringen", "c3": "Mit-bring-en", "c4": "Bringen Sie die Karte mit.", "c5": "Bring-en zee dee Kar-teh mit", "c6": "Bring the card along." }
