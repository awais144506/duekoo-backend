    {
      "type": "EXPLAINER",
      "title": "The “Tail” Rule",
      "blocks": [
        {
          "heading": "Separable Verbs in Commands",
          "text": "In German, the word for 'To Turn' is 'Abbiegen'. When used in a command, the 'Ab' (the tail) gets kicked to the very end of the sentence.",
          "examples": [
            { "exp1": "Turn left. → Biegen Sie links ab." },
            { "exp2": "Turn right. → Biegen Sie rechts ab." }
          ]
        }
      ]
    }
