  "type": "COMPOSITE",
  "title": "Directions & Imperatives",
  "deTitle": "Richtungen & Imperativ",
  "sections": [
    {
      "type": "EXPLAINER",
      "title": "Polite Commands",
      "blocks": [
        {
          "heading": "The Imperative Formula",
          "text": "To give a polite order or direction, the formula is very simple: Action Verb + Sie + Direction.",
          "examples": [
            { "exp1": "Gehen (To go) + Sie = Gehen Sie... (Go...)" }
          ]
        }
      ]
    },
    {
      "type": "TABLE",
      "title": "Basic Imperative Verbs",
      "config": {
        "speechSequence": ["c2"]
      },
      "headers": ["English", "German", "Pronunciation", "Meaning"],
      "rows": [
        { "c1": "Go", "c2": "Gehen Sie...", "c3": "Gay-en zee", "c4": "Go..." },
        { "c1": "Drive / Travel", "c2": "Fahren Sie...", "c3": "Fah-ren zee", "c4": "Drive / Travel..." },
        { "c1": "Take", "c2": "Nehmen Sie...", "c3": "Nay-men zee", "c4": "Take..." },
        { "c1": "Wait", "c2": "Warten Sie...", "c3": "Var-ten zee", "c4": "Wait..." },
        { "c1": "Turn", "c2": "Biegen Sie... ab", "c3": "Bee-gen zee... ab", "c4": "Turn..." }
      ]
