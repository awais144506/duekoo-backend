        { "c1": "Left", "c2": "Links", "c3": "Links", "c4": "Gehen Sie links.", "c5": "Go left." },
        { "c1": "Right", "c2": "Rechts", "c3": "Rekhts", "c4": "Biegen Sie rechts ab.", "c5": "Turn right." },
        { "c1": "Straight ahead", "c2": "Geradeaus", "c3": "Geh-rah-deh-ows", "c4": "Fahren Sie geradeaus.", "c5": "Drive straight." },
        { "c1": "Back", "c2": "Zurück", "c3": "Tsoo-ruek", "c4": "Gehen Sie zurück.", "c5": "Go back." },
