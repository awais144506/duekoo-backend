      "rows": [
        {
          "c1": "Und",
          "c2": "And",
          "c3": "Ich habe den Pass und das Visum.",
          "c4": "Ikh ha-buh deyn Pass oont das Vee-zoom",
          "c5": "I have the passport and the visa."
        },
        {
          "c1": "Aber",
          "c2": "But",
          "c3": "Der Koffer ist groß, aber nicht schwer.",
          "c4": "Deyr Koff-er ist grohs, ah-ber nikht shveyr",
          "c5": "The suitcase is big, but not heavy."
        },
        {
          "c1": "Oder",
          "c2": "Or",
          "c3": "Nehmen wir das Taxi oder den Bus?",
          "c4": "Nay-men veer das Tak-see oh-der deyn Boos?",
          "c5": "Are we taking the taxi or the bus?"
        },
        {
          "c1": "Weil",
          "c2": "Because",
          "c3": "Ich warte, weil der Flug spät ist.",
          "c4": "Ikh var-tuh, vile deyr Floog shpayt ist",
          "c5": "I am waiting because the flight is late."
        },
        {
          "c1": "Denn",
          "c2": "Because / For",
          "c3": "Ich warte, denn ich habe Zeit.",
          "c4": "Ikh var-tuh, dehn ikh ha-buh Tsyte",
          "c5": "I am waiting, for I have time."
        }
      ]
    },
    {
      "type": "TABLE",
      "title": "Interjections (Interjektionen)",
      "config": {
        "speechSequence": [
          "c1",
          "c3"
        ]
      },
      "headers": [
        "German",
        "English",
        "Example",
