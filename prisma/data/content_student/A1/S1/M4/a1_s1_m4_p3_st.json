      ],
      "rows": [
        {
          "c1": "Oh!",
          "c2": "Oh!",
          "c3": "Oh! Mein Visum ist hier!",
          "c4": "Oh! Mine Vee-zoom ist heer",
          "c5": "Oh! My visa is here!"
        },
        {
          "c1": "Wow!",
          "c2": "Wow!",
          "c3": "Wow! Das Terminal ist groß!",
          "c4": "Wow! Das Ter-mi-nal ist grohs",
          "c5": "Wow! The terminal is big!"
        },
        {
          "c1": "Na?",
          "c2": "Hey / So?",
          "c3": "Na? Wie geht's?",
          "c4": "Nah? Vee gayts",
          "c5": "Hey? How's it going?"
        },
        {
          "c1": "Wahnsinn!",
          "c2": "Incredible!",
          "c3": "Wahnsinn! Der Flug kostet nur 20 Euro!",
          "c4": "Vahn-zin! Deyr Floog kos-tet noor tsvan-tsikh Oy-roh",
          "c5": "Incredible! The flight only costs 20 Euro!"
        },
        {
          "c1": "Naja...",
          "c2": "Well...",
          "c3": "Naja... der Koffer ist okay.",
          "c4": "Nah-ya... deyr Koff-er ist oh-kay",
          "c5": "Well... the suitcase is okay."
        },
        {
          "c1": "Ach!",
          "c2": "Oh! / Ah!",
          "c3": "Ach! Ich habe mein Ticket vergessen!",
          "c4": "Akh! Ikh ha-buh mine Tik-et fer-geh-sen",
          "c5": "Ah! I forgot my ticket!"
        },
        {
          "c1": "Super!",
          "c2": "Great!",
          "c3": "Super! Das Taxi ist da!",
          "c4": "Zoo-per! Das Tak-see ist dah",
          "c5": "Great! The taxi is here!"
        },
        {
          "c1": "Mist!",
          "c2": "Crap!",
          "c3": "Mist! Ich bin zu spät!",
          "c4": "Mist! Ikh bin tsoo shpayt",
          "c5": "Crap! I am too late!"
        },
        {
          "c1": "Gott sei Dank!",
          "c2": "Thank God!",
          "c3": "Gott sei Dank! Mein Koffer ist da.",
          "c4": "Got zy dank! Mine Koff-er ist dah",
          "c5": "Thank God! My suitcase is there."
        },
        {
          "c1": "Wirklich?",
          "c2": "Really?",
          "c3": "Wirklich? Der Bus kommt?",
          "c4": "Veerk-likh? Deyr Boos komt",
          "c5": "Really? The bus is coming?"
        },
        {
          "c1": "Hoppla",
          "c2": "Oops",
          "c3": "Hoppla! Entschuldigung",
          "c4": "Hop-la! Ent-shool-dee-goong",
          "c5": "Oops! Excuse me."
        }
      ]
    },
