generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum Intake {
  SUMMER
  WINTER
}

enum ProgressStatus {
  LOCKED
  UNLOCKED
  COMPLETED
}

// --- 1. Identity & Profile ---

model User {
  id            String               @id @default(cuid())
  email         String               @unique
  firstName     String?
  lastName      String?
  imageUrl      String?
  profile       UserProfile?
  currentPos    UserCurrentPosition?
  levelProgress LevelProgress[]
  moduleStatus  ModuleStatus[]
  certificates  Certificate[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model UserProfile {
  id             String  @id @default(cuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dob            DateTime?
  passportNum    String?
  program        String?
  universityName String?
  country        String?
  phoneNo        String?
  intake         Intake?
  hasSeenWelcome Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// --- 2. Course Structure (The Skeleton) ---

model Level {
  id          String          @id @default(cuid())
  slug        String          @unique // "A1", "A2"
  title       String
  order       Int
  sections    Section[]
  progress    LevelProgress[]
  certificates Certificate[]
  currentPos  UserCurrentPosition[]
}

model Section {
  id         String   @id @default(cuid())
  levelId    String
  level      Level    @relation(fields: [levelId], references: [id])
  title      String
  order      Int
  modules    Module[]
  currentPos UserCurrentPosition[]
}

model Module {
  id         String         @id @default(cuid())
  sectionId  String
  section    Section        @relation(fields: [sectionId], references: [id])
  title      String
  order      Int
  parts      Part[]
  statuses   ModuleStatus[]
  currentPos UserCurrentPosition[]
}

model Part {
  id         String   @id @default(cuid())
  moduleId   String
  module     Module   @relation(fields: [moduleId], references: [id])
  title      String
  contentId  String   // Frontend JSON Key
  order      Int
  currentPos UserCurrentPosition[]
}

// --- 3. User Progress & State Tracking ---

model UserCurrentPosition {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  levelId   String
  level     Level    @relation(fields: [levelId], references: [id])
  sectionId String
  section   Section  @relation(fields: [sectionId], references: [id])
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id])
  partId    String
  part      Part     @relation(fields: [partId], references: [id])
  updatedAt DateTime @updatedAt
}

model LevelProgress {
  id                 String         @id @default(cuid())
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  levelId            String
  level              Level          @relation(fields: [levelId], references: [id])
  progressPercentage Int            @default(0)
  status             ProgressStatus @default(LOCKED)
  updatedAt          DateTime       @updatedAt

  @@unique([userId, levelId]) // Prevent double entries for same level
}

model ModuleStatus {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id])
  isCompleted Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@unique([userId, moduleId])
}

// --- 4. The Certificate & Verification System ---

model Certificate {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  levelId           String
  level             Level    @relation(fields: [levelId], references: [id])
  certificateNo     String   @unique // e.g., "234406"
  issueDate         DateTime @default(now())
  fileUrl           String   // S3/Cloudinary Link
  verificationToken String   @unique @default(uuid()) // For QR code link
  isRevoked         Boolean  @default(false)
  createdAt         DateTime @default(now())
}